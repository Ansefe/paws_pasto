# Supabase Configuration
# Copia este archivo a .env y reemplaza con tus valores de Supabase
# Los valores se encuentran en: Supabase Dashboard > Project Settings > API

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Telegram Bot - Notificaciones de postulaciones (recomendado)
# 1. Crea un bot con @BotFather en Telegram (envía /newbot)
# 2. Guarda el token que te da
# 3. Crea un grupo y añade el bot como administrador
# 4. Obtén el chat_id del grupo visitando:
#    https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#    (después de enviar un mensaje al grupo)
VITE_TELEGRAM_BOT_TOKEN=tu-bot-token-aqui
VITE_TELEGRAM_CHAT_ID=tu-chat-id-aqui
